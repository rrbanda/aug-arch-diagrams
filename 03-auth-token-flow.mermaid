sequenceDiagram
    actor User
    participant Browser as Orion Frontend
    participant Backend as Orion Backend
    participant SecMW as Security Middleware
    participant TM as KeycloakTokenManager
    participant KC as Keycloak
    participant RHAO as Red Hat Agent Operator
    participant AuthBridge as Auth Bridge / Proxy
    participant Pod as Agent Pod

    rect rgb(238, 242, 255)
    Note over User,Browser: User sends chat message
    User->>Browser: Type message, click Send
    Browser->>Backend: POST /api/augment/chat/stream<br/>Cookie: backstage-session<br/>X-Backstage-Request: augment
    end

    rect rgb(254, 226, 226)
    Note over Backend,SecMW: Security Mode Check
    Backend->>SecMW: requirePluginAccess(req)
    alt mode = none
        SecMW->>SecMW: Skip access control (dev mode)
    else mode = plugin-only
        SecMW->>SecMW: Verify Backstage plugin access
    else mode = full
        SecMW->>SecMW: Check augment.access permission via RBAC
    end
    end

    rect rgb(219, 234, 254)
    Note over Backend: Identity Resolution
    Backend->>Backend: httpAuth.credentials(req, allow: [user, none])
    alt Authenticated user
        Backend->>Backend: userRef = principal.userEntityRef
    else Unauthenticated (mode=none)
        Backend->>Backend: userRef = user:default/guest (fallback)
    end
    Backend->>Backend: provider.setUserContext(userRef)
    end

    rect rgb(254, 226, 226)
    Note over TM,KC: Token Acquisition
    Backend->>TM: getTokenForStreaming(300000ms)
    TM->>TM: Check cached token + lifetime

    alt Token valid with sufficient lifetime
        TM-->>Backend: Cached JWT
    else Token expired or insufficient
        TM->>KC: POST /realms/kagenti/protocol/openid-connect/token
        Note over TM,KC: grant_type=client_credentials<br/>client_id=kagenti-api<br/>client_secret=***
        KC->>KC: Issue JWT with default client scopes
        Note over KC: JWT aud claim includes:<br/>SPIFFE IDs for all registered agents<br/>Platform audience<br/><br/>Scopes auto-managed by Operator
        KC-->>TM: {access_token, expires_in: 1800}
        TM->>TM: Cache (lifetime - 60s buffer)
        TM-->>Backend: Fresh JWT
    end
    end

    rect rgb(209, 250, 229)
    Note over Backend,Pod: Chat Request
    Backend->>RHAO: POST /api/v1/chat/ns/agent/stream<br/>Authorization: Bearer {JWT}<br/>X-Backstage-User: {userRef}
    RHAO->>RHAO: Validate JWT signature + expiry + roles
    RHAO->>AuthBridge: Forward with token
    AuthBridge->>AuthBridge: Validate JWT aud contains agent SPIFFE ID
    end

    alt Audience valid
        rect rgb(209, 250, 229)
        AuthBridge->>Pod: Forward A2A request (authenticated)
        Pod->>Pod: Process message with LLM
        Pod-->>RHAO: SSE stream events
        RHAO-->>Backend: Forward stream
        Backend-->>Browser: data: {type: stream.text.delta, ...}
        end
    else Audience mismatch
        rect rgb(254, 226, 226)
        AuthBridge-->>RHAO: 401 token validation failed
        RHAO-->>Backend: {error: auth.unauthorized}
        Backend->>TM: clearCache() + retry once
        Backend-->>Browser: data: {type: stream.error, error: "..."}
        end
    end
